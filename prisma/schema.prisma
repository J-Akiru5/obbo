// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                      String            @id @db.Uuid
  email                   String
  fullName                String            @default("") @map("full_name")
  firstName               String?           @map("first_name")
  surname                 String?
  accountType             String?           @map("account_type")
  companyName             String?           @map("company_name")
  contactPersonFirstName  String?           @map("contact_person_first_name")
  contactPersonSurname    String?           @map("contact_person_surname")
  phone                   String?
  addressStreet           String?           @map("address_street")
  addressCity             String?           @map("address_city")
  addressProvince         String?           @map("address_province")
  addressPostalCode       String?           @map("address_postal_code")
  businessPermitNo        String?           @map("business_permit_no")
  tinNo                   String?           @map("tin_no")
  kycDocuments            String[]          @map("kyc_documents")
  kycStatus               String            @default("pending_verification") @map("kyc_status")
  role                    String            @default("client")
  avatarUrl               String?           @map("avatar_url")
  notificationPreferences Json?             @default("{\"order_approval\":true,\"payment_required\":true,\"dispatch\":true,\"delivery_status\":true}") @map("notification_preferences")
  createdAt               DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt               DateTime          @default(now()) @db.Timestamptz(6) @map("updated_at")

  orders           Order[]
  deliveryReceipts DeliveryReceipt[]
  customerBalances CustomerBalance[]
  purchaseOrders   PurchaseOrder[]
  activityLogs     ActivityLog[]
  orderReturns     OrderReturn[]
  notifications    Notification[]

  @@map("profiles")
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String   @default("")
  bagType        String   @map("bag_type")
  pricePerBag    Decimal  @db.Decimal(12, 2) @map("price_per_bag")
  pricePort      Decimal? @db.Decimal(12, 2) @map("price_port")
  priceWarehouse Decimal? @db.Decimal(12, 2) @map("price_warehouse")
  imageUrl       String?  @map("image_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  orderItems       OrderItem[]
  customerBalances CustomerBalance[]

  @@unique([name, bagType], name: "products_name_bag_type_key")
  @@map("products")
}

model Shipment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchName       String   @unique @map("batch_name")
  productId       String?  @db.Uuid @map("product_id")
  bagType         String?  @map("bag_type")
  initialQuantity Int      @default(0) @map("initial_quantity")
  goodStock       Int      @default(0) @map("good_stock")
  damagedStock    Int      @default(0) @map("damaged_stock")
  totalJb         Int      @default(0) @map("total_jb")
  totalSb         Int      @default(0) @map("total_sb")
  remainingJb     Int      @default(0) @map("remaining_jb")
  remainingSb     Int      @default(0) @map("remaining_sb")
  arrivalDate     DateTime @db.Date @map("arrival_date")
  notes           String?
  damagedJb       Int      @default(0) @map("damaged_jb")
  damagedSb       Int      @default(0) @map("damaged_sb")
  createdAt       DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  ledgerEntries    ShipmentLedger[]
  deliveryReceipts DeliveryReceipt[]
  orders           Order[]
  purchaseOrders   PurchaseOrder[]

  @@map("shipments")
}

model ShipmentLedger {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId          String   @db.Uuid @map("shipment_id")
  date                DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  poNumber            String?  @map("po_number")
  drNumber            String?  @map("dr_number")
  clientName          String?  @map("client_name")
  driverName          String?  @map("driver_name")
  plateNumber         String?  @map("plate_number")
  destination         String?
  serviceType         String?  @map("service_type")
  jb                  Int      @default(0)
  sb                  Int      @default(0)
  paymentMethod       String?  @map("payment_method")
  checkNumber         String?  @map("check_number")
  amount              Decimal? @db.Decimal(14, 2)
  bagsReturned        Int      @default(0) @map("bags_returned")
  bagReturnedType     String?  @map("bag_returned_type")
  returnReason        String   @default("return") @map("return_reason")
  clientReason        String?  @map("client_reason")
  notes               String?
  totalSales          Decimal? @default(0) @db.Decimal(14, 2) @map("total_sales")
  grossProfit         Decimal? @default(0) @db.Decimal(14, 2) @map("gross_profit")
  netProfit           Decimal? @default(0) @db.Decimal(14, 2) @map("net_profit")
  sellingPricePerBag  Decimal? @db.Decimal(10, 2) @map("selling_price_per_bag")
  landedCostPerBag    Decimal? @db.Decimal(10, 2) @map("landed_cost_per_bag")
  localExpensesPerBag Decimal? @db.Decimal(10, 2) @map("local_expenses_per_bag")
  createdAt           DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_ledger")
}

model DeliveryReceipt {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId   String   @db.Uuid @map("shipment_id")
  drNumber     String   @unique @map("dr_number")
  quantity     Int
  bagType      String   @map("bag_type")
  receivedDate DateTime @db.Date @map("received_date")
  notes        String?
  poNumber     String?  @map("po_number")
  clientName   String?  @map("client_name")
  clientId     String?  @db.Uuid @map("client_id")
  jb           Int      @default(0)
  sb           Int      @default(0)
  driver       String?
  plateNumber  String?  @map("plate_number")
  shippingFee  Decimal? @db.Decimal(12, 2) @map("shipping_fee")
  drImageUrl   String?  @map("dr_image_url")
  destination  String?
  orderId      String?  @db.Uuid @map("order_id")
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  profile  Profile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("delivery_receipts")
}

model Order {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String    @db.Uuid @map("client_id")
  status              String    @default("pending")
  totalAmount         Decimal   @default(0) @db.Decimal(14, 2) @map("total_amount")
  paymentMethod       String    @map("payment_method")
  checkImageUrl       String?   @map("check_image_url")
  checkNumber         String?   @map("check_number")
  notes               String?
  poNumber            String?   @map("po_number")
  poImageUrl          String?   @map("po_image_url")
  source              String    @default("port")
  serviceType         String    @default("deliver") @map("service_type")
  shippingFee         Decimal   @default(0) @db.Decimal(12, 2) @map("shipping_fee")
  drNumber            String?   @map("dr_number")
  drImageUrl          String?   @map("dr_image_url")
  driverName          String?   @map("driver_name")
  plateNumber         String?   @map("plate_number")
  rejectionReason     String?   @map("rejection_reason")
  trackingStatus      String    @default("pending_dispatch") @map("tracking_status")
  bagsReturnedJb      Int       @default(0) @map("bags_returned_jb")
  bagsReturnedSb      Int       @default(0) @map("bags_returned_sb")
  shipmentId          String?   @db.Uuid @map("shipment_id")
  isSplitDelivery     Boolean   @default(false) @map("is_split_delivery")
  deliverNowQty       Int       @default(0) @map("deliver_now_qty")
  supplierName        String?   @map("supplier_name")
  preferredPickupDate DateTime? @db.Date @map("preferred_pickup_date")
  orderType           String    @default("new") @map("order_type")
  linkedPoNumber      String?   @map("linked_po_number")
  createdAt           DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime  @default(now()) @db.Timestamptz(6) @map("updated_at")

  profile  Profile   @relation(fields: [clientId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  orderItems       OrderItem[]
  customerBalances CustomerBalance[]
  deliveryReceipts DeliveryReceipt[]
  purchaseOrders   PurchaseOrder[]
  orderReturns     OrderReturn[]

  @@map("orders")
}

model OrderItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId             String   @db.Uuid @map("order_id")
  productId           String   @db.Uuid @map("product_id")
  bagType             String   @map("bag_type")
  requestedQty        Int      @map("requested_qty")
  approvedQty         Int      @default(0) @map("approved_qty")
  dispatchedQty       Int      @default(0) @map("dispatched_qty")
  sellingPricePerBag  Decimal? @db.Decimal(10, 2) @map("selling_price_per_bag")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model CustomerBalance {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @db.Uuid @map("client_id")
  orderId      String   @db.Uuid @map("order_id")
  productId    String   @db.Uuid @map("product_id")
  bagType      String   @map("bag_type")
  remainingQty Int      @map("remaining_qty")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  profile Profile @relation(fields: [clientId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("customer_balances")
}

model PurchaseOrder {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date        DateTime @default(dbgenerated("current_date")) @db.Date
  poNumber    String   @unique @map("po_number")
  clientId    String?  @db.Uuid @map("client_id")
  clientName  String?  @map("client_name")
  jb          Int      @default(0)
  sb          Int      @default(0)
  status      String   @default("pending")
  source      String?
  serviceType String?  @map("service_type")
  shipmentId  String?  @db.Uuid @map("shipment_id")
  orderId     String?  @db.Uuid @map("order_id")
  checkNumber String?  @map("check_number")
  checkAmount Decimal? @db.Decimal(12, 2) @map("check_amount")
  cashAmount  Decimal? @db.Decimal(12, 2) @map("cash_amount")
  photoUrl    String?  @map("photo_url")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  profile  Profile?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("purchase_orders")
}

model WarehouseReport {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportDate   DateTime @unique @db.Date @map("report_date")
  yesterdayJb  Int      @default(0) @map("yesterday_jb")
  yesterdaySb  Int      @default(0) @map("yesterday_sb")
  receivedJb   Int      @default(0) @map("received_jb")
  receivedSb   Int      @default(0) @map("received_sb")
  dispatchedJb Int      @default(0) @map("dispatched_jb")
  dispatchedSb Int      @default(0) @map("dispatched_sb")
  returnedJb   Int      @default(0) @map("returned_jb")
  returnedSb   Int      @default(0) @map("returned_sb")
  wasteJb      Int      @default(0) @map("waste_jb")
  wasteSb      Int      @default(0) @map("waste_sb")
  closingJb    Int      @default(0) @map("closing_jb")
  closingSb    Int      @default(0) @map("closing_sb")
  notes        String?
  submitted    Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("warehouse_reports")
}

model AdminSetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json     @default("{}")
  updatedAt DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("admin_settings")
}

model ActivityLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @db.Uuid @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  profile Profile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("activity_log")
}

model OrderReturn {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid @map("order_id")
  clientId  String   @db.Uuid @map("client_id")
  jbQty     Int      @default(0) @map("jb_qty")
  sbQty     Int      @default(0) @map("sb_qty")
  reason    String   @default("")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [clientId], references: [id])

  @@map("order_returns")
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  title      String
  message    String
  href       String?
  severity   String   @default("info")
  targetRole String?  @map("target_role")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}